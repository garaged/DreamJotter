/*
 English is DreamJotter's development language. UI source strings are already
 English, so untranslated keys intentionally fall back to the key itself.

 Keeping a real English localization directory ensures that SwiftPM and the
 packaged app agree with defaultLocalization / CFBundleDevelopmentRegion and
 gives Foundation a concrete development-language fallback bundle.
*/
"DreamJotterLocalizationFallback" = "DreamJotterLocalizationFallback";
