#!/usr/bin/env python3
import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
TEMPLATE_PATH = ROOT / "docs" / "templates" / "feature-spec-template.md"


def usage():
    print("Usage: scripts/spec-new <id> <title> <milestone> <destination-path>")
    print("Example: scripts/spec-new PRD-EDITOR-002 'Editor Commands' M2 docs/specs/editor-commands.md")


def slugify(value):
    value = value.lower()
    value = re.sub(r"[^a-z0-9]+", "-", value)
    return value.strip("-") or "feature"


def main(argv):
    if len(argv) != 5:
        usage()
        return 2

    spec_id, title, milestone, destination = argv[1:]
    destination_path = ROOT / destination
    if destination_path.exists():
        print(f"FAIL destination already exists: {destination}")
        return 1

    template = TEMPLATE_PATH.read_text(encoding="utf-8")
    content = template.replace("FEATURE-ID", spec_id)
    content = content.replace("Feature Title", title)
    content = content.replace("milestone: M1", f"milestone: {milestone}")
    content = content.replace("# " + title, "# " + title)
    content = content.replace("status: idea", "status: idea")
    content = content.replace("Describe the feature in one or two concrete paragraphs.", f"Describe `{spec_id}` here.")

    destination_path.parent.mkdir(parents=True, exist_ok=True)
    destination_path.write_text(content, encoding="utf-8")
    print(f"Created {destination} from feature template")
    print("Reminder: add this spec to specs/registry.yml before implementation.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
